{
  "name": "htmledger",
  "version": "2.0.2",
  "author": "localhost:314 | localhost314.com",
  "description": "HTML file viewer, creator, and editor",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:store": "electron-builder --win --x64 --config.win.target=appx"
  },
  "build": {
    "appId": "com.htmledger.app",
    "productName": "HTMLedger",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "appx": {
      "identityName": "localhost314.HTMLedger",
      "publisher": "CN=4F168544-70A7-4A96-864D-CD21272D099F",
      "publisherDisplayName": "localhost:314",
      "applicationId": "HTMLedger",
      "backgroundColor": "#1a1a2e",
      "showNameOnTiles": true
    },
    "publish": {
      "provider": "github",
      "owner": "localhost-314",
      "repo": "HTMLedger",
      "releaseType": "release"
    },
    "fileAssociations": [
      {
        "ext": ["html", "htm", "css", "js", "jsx", "ts", "tsx", "json", "xml", "svg", "md"],
        "name": "HTMLedger Document",
        "description": "Open with HTMLedger",
        "role": "Editor"
      }
    ],
    "files": [
      "**/*",
      "!node_modules/.cache"
    ]
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "emmet": "^2.4.11",
    "monaco-editor": "^0.55.1"
  },
  "allowScripts": {
    "electron@31.7.7": true
  }
}
